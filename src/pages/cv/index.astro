---
import Base from '../../layouts/Base.astro';

const lastUpdated = 'June 2026';
---
<Base
  title="CV — Amit Goyal"
  description="Curriculum vitae of Amit Goyal — Economics Coach at Econschool, Academic Specialist at NYU Abu Dhabi."
  current="cv"
>
  <!-- ====== HEADER ====== -->
  <section class="cv-header">
    <p class="eyebrow">Curriculum vitae</p>
    <h1>Amit Kumar Goyal</h1>
    <p class="cv-tagline">
      Economics Coach, <a href="https://econschool.in">Econschool</a> &middot;
      Academic Specialist, NYU Abu Dhabi
    </p>
    <p class="cv-meta">
      Delhi &middot; Abu Dhabi &nbsp;&middot;&nbsp;
      <a href="mailto:amit@econschool.in">amit@econschool.in</a>
      &nbsp;&middot;&nbsp; +91 98185 17101
    </p>
    <p class="cv-download">
      <a href="/cv.pdf" download>Download PDF &darr;</a>
      <span class="cv-updated">Last updated {lastUpdated}</span>
    </p>
  </section>

  <hr class="rule-sage" />

  <!-- ====== RESEARCH INTERESTS ====== -->
  <section class="cv-section">
    <h2>Research interests</h2>
    <p class="cv-prose">Microeconomic theory; economic education.</p>
  </section>

  <hr class="rule-sage" />

  <!-- ====== EDUCATION ====== -->
  <section class="cv-section">
    <h2>Education</h2>
    <div class="cv-entries">
      <article class="cv-entry">
        <div class="cv-date">2009&ndash;14, 2022&ndash;present</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">PhD, Economics</h3>
          <p class="cv-org">Indian Statistical Institute, New Delhi</p>
          <p class="cv-detail">Advisors: Arunava Sen and Debasis Mishra.</p>
        </div>
      </article>

      <article class="cv-entry">
        <div class="cv-date">2005&ndash;09</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">PhD programme, Economics &amp; Operations Research</h3>
          <p class="cv-org">The Pennsylvania State University &mdash; non-graduating</p>
          <p class="cv-detail">
            Completed 3.5 years of coursework; 86 credits, GPA 3.71/4.00. Advisor: Kalyan Chatterjee.
          </p>
        </div>
      </article>

      <article class="cv-entry">
        <div class="cv-date">2002&ndash;04</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">MA, Economics &mdash; First Division</h3>
          <p class="cv-org">Delhi School of Economics, University of Delhi</p>
        </div>
      </article>

      <article class="cv-entry">
        <div class="cv-date">1999&ndash;2002</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">BA (Hons.), Economics &mdash; First Division</h3>
          <p class="cv-org">Ramjas College, University of Delhi</p>
        </div>
      </article>
    </div>
  </section>

  <hr class="rule-sage" />

  <!-- ====== RESEARCH ====== -->
  <section class="cv-section">
    <h2>Research</h2>
    <ul class="cv-list">
      <li>
        <span class="cv-paper-title">Timing of the Tie-Breaker</span>
        <span class="cv-paper-meta">with Sumit Goel and Nidhi Jain</span>
        <span class="cv-paper-links">
          <a href="https://www.researchgate.net/publication/373863256_Timing_of_the_Tie-Breaker" target="_blank" rel="noopener noreferrer">PDF</a> &middot; <a href="https://youtu.be/LI5SruNMXZ4" target="_blank" rel="noopener noreferrer">Video lecture</a>
        </span>
      </li>
      <li>
        <span class="cv-paper-title">Optimal Tie-Breaking Rules</span>
        <span class="cv-paper-meta">with Sumit Goel</span>
        <span class="cv-paper-links">
          <a href="https://arxiv.org/abs/2304.13866" target="_blank" rel="noopener noreferrer">arXiv</a>
        </span>
      </li>
    </ul>
  </section>

  <hr class="rule-sage" />

  <!-- ====== POSITIONS ====== -->
  <section class="cv-section">
    <h2>Positions</h2>
    <div class="cv-entries">
      <article class="cv-entry">
        <div class="cv-date">Jan 2025&ndash;present</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">Academic Specialist</h3>
          <p class="cv-org">New York University Abu Dhabi</p>
          <p class="cv-detail">
            Conducts recitations, sets examinations, and grades assessments in undergraduate and
            graduate economics courses.
          </p>
        </div>
      </article>

      <article class="cv-entry">
        <div class="cv-date">Aug 2009&ndash;present</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">Founder &amp; Economics Coach</h3>
          <p class="cv-org">Econschool</p>
          <p class="cv-detail">
            Runs a rigorous preparatory programme for students targeting MA and PhD admissions at
            DSE, ISI, and international programmes. Designs and delivers workshops on Python, R,
            and AI tools with applications in economics, mathematics, and statistics. Maintains
            an active online forum for aspiring graduate students worldwide.
          </p>
        </div>
      </article>

      <article class="cv-entry">
        <div class="cv-date">Aug 2017&ndash;Aug 2023</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">Visiting Faculty</h3>
          <p class="cv-org">Ashoka University</p>
          <p class="cv-detail">
            Taught Statistics for Economics, Mathematics for Economics, and Machine Learning for
            Economics.
          </p>
        </div>
      </article>

      <article class="cv-entry">
        <div class="cv-date">May 2004&ndash;May 2005</div>
        <div class="cv-body">
          <h3 class="cv-entry-title">Business Analyst</h3>
          <p class="cv-org">American Express</p>
        </div>
      </article>
    </div>
  </section>

  <hr class="rule-sage" />

  <!-- ====== TEACHING ====== -->
  <section class="cv-section">
    <h2>Teaching</h2>

    <h3 class="cv-subhead">Econschool</h3>
    <ul class="cv-list cv-list--tight">
      <li><span class="cv-course">Preparatory Programme for Higher Studies in Economics</span><span class="cv-when">2009&ndash;present</span></li>
      <li><span class="cv-course">Programme in Microeconomic Theory</span><span class="cv-when">Feb 2024&ndash;Jan 2025</span></li>
      <li><span class="cv-course">Summer School in Game Theory</span><span class="cv-when">Summer 2022</span></li>
    </ul>

    <h3 class="cv-subhead">Ashoka University</h3>
    <ul class="cv-list cv-list--tight">
      <li><span class="cv-course">Machine Learning for Economics</span><span class="cv-when">Summers 2022&ndash;23; Spring 2023</span></li>
      <li><span class="cv-course">Statistics for Economics</span><span class="cv-when">Monsoon 2017&ndash;2022</span></li>
      <li><span class="cv-course">Mathematics for Economics</span><span class="cv-when">Springs 2018&ndash;19, 2021&ndash;22</span></li>
    </ul>

    <h3 class="cv-subhead">Indian Statistical Institute</h3>
    <ul class="cv-list cv-list--tight">
      <li><span class="cv-course">Intensive Math Camp for incoming students</span><span class="cv-when">Aug 2022</span></li>
      <li><span class="cv-course">Teaching Assistant, Econ 271A: Microeconomics I</span><span class="cv-when">Fall 2010, 2011</span></li>
    </ul>

    <h3 class="cv-subhead">Other institutions</h3>
    <ul class="cv-list cv-list--tight">
      <li><span class="cv-course">Managerial Economics (Microeconomics) &mdash; Masters&rsquo; Union</span><span class="cv-when">Apr&ndash;May 2024</span></li>
      <li><span class="cv-course">Principles of Microeconomics &mdash; Shiv Nadar University</span><span class="cv-when">Spring 2024</span></li>
      <li><span class="cv-course">Optimisation for Decision Making &mdash; Masters&rsquo; Union</span><span class="cv-when">Aug&ndash;Sep 2022</span></li>
      <li><span class="cv-course">Applied Microeconomics &mdash; Meghnad Desai Academy of Economics</span><span class="cv-when">Sep 2016</span></li>
      <li><span class="cv-course">Probability and Statistics (short course) &mdash; OP Jindal University</span><span class="cv-when">Aug 2015</span></li>
      <li><span class="cv-course">Topics in Microeconomics &mdash; Kirori Mal College, University of Delhi</span><span class="cv-when">Nov 2009&ndash;Mar 2010</span></li>
    </ul>
  </section>

  <hr class="rule-sage" />

  <!-- ====== PRESENTATIONS ====== -->
  <section class="cv-section">
    <h2>Presentations &amp; workshops</h2>
    <ul class="cv-list cv-list--tight">
      <li><span class="cv-course">Economics, Mathematics &amp; Statistics with R and Python &mdash; Econschool, Delhi</span><span class="cv-when">Dec 2021&ndash;present</span></li>
      <li><span class="cv-course">Seminars, Winter School &amp; other events &mdash; Econschool, Delhi</span><span class="cv-when">Jul 2023&ndash;present</span></li>
      <li><span class="cv-course">Timing of the Tie-Breaker &mdash; Indian Statistical Institute, Delhi</span><span class="cv-when">Feb 2024</span></li>
      <li><span class="cv-course">Timing of the Tie-Breaker &mdash; Winter School, Delhi School of Economics</span><span class="cv-when">Dec 2023</span></li>
      <li><span class="cv-course">Probability and Statistics with R &mdash; University of Delhi</span><span class="cv-when">Oct 2019, Jan 2016</span></li>
      <li><span class="cv-course">Probability and Statistics with R &mdash; IIT Guwahati</span><span class="cv-when">Mar 2017</span></li>
      <li><span class="cv-course">Dynamic General Equilibrium Models with Matlab (with Pawan Gopalakrishnan) &mdash; Miranda House, University of Delhi</span><span class="cv-when">Mar 2016</span></li>
      <li><span class="cv-course">Have Patience, It&rsquo;s Good &mdash; Summer School on Bounded Rationality, Seoul</span><span class="cv-when">Aug 2013</span></li>
    </ul>
  </section>

  <hr class="rule-sage" />

  <!-- ====== EDUCATIONAL MEDIA ====== -->
  <section class="cv-section">
    <h2>Educational media</h2>

    <article class="cv-entry">
      <div class="cv-date">Ongoing</div>
      <div class="cv-body">
        <h3 class="cv-entry-title">YouTube &mdash; @econ.school</h3>
        <p class="cv-org">
          <a href="https://www.youtube.com/@econ.school" target="_blank" rel="noopener">youtube.com/@econ.school</a>
        </p>
        <p class="cv-detail">
          Lecture series and problem-solving videos; about 9,000 subscribers. Playlists span
          consumer theory, general equilibrium, production and cost, competitive equilibrium,
          monopoly, static and dynamic games, externalities, public goods, convexity and
          optimisation methods, and introductions to Python and R for probability.
        </p>
      </div>
    </article>

    <article class="cv-entry">
      <div class="cv-date">2024</div>
      <div class="cv-body">
        <h3 class="cv-entry-title">The Econ Artbook</h3>
        <p class="cv-org">Self-published</p>
        <p class="cv-detail">
          A 100-page collection of mathematical postcards drawn in TikZ &mdash; economic
          concepts rendered as visual art. Part of a broader effort to make rigorous
          economics more accessible and aesthetically compelling.
          See the <a href="/artbook/">gallery</a>.
        </p>
      </div>
    </article>
  </section>

  <hr class="rule-sage" />

  <!-- ====== FELLOWSHIPS & AWARDS ====== -->
  <section class="cv-section">
    <h2>Fellowships &amp; awards</h2>
    <ul class="cv-list cv-list--tight">
      <li><span class="cv-course">Research Fellowship &mdash; Indian Statistical Institute</span><span class="cv-when">Aug 2009&ndash;Aug 2013</span></li>
      <li><span class="cv-course">Graduate Assistantship &mdash; The Pennsylvania State University</span><span class="cv-when">Aug 2005&ndash;Dec 2008</span></li>
      <li><span class="cv-course">Career Advancement Scholarship (National) &mdash; Delhi School of Economics</span><span class="cv-when">Jul 2002&ndash;May 2004</span></li>
      <li><span class="cv-course">Best Student of the Year Award &mdash; Ramjas College, University of Delhi</span><span class="cv-when">Mar 2002</span></li>
    </ul>
  </section>

  <hr class="rule-sage" />

  <!-- ====== LINKS ====== -->
  <section class="cv-section">
    <h2>Elsewhere</h2>
    <ul class="cv-links">
      <li><a href="https://www.youtube.com/@econ.school" target="_blank" rel="noopener">YouTube &mdash; @econ.school</a></li>
      <li><a href="https://github.com/amitkumargoyal" target="_blank" rel="noopener">GitHub</a></li>
      <li><a href="https://twitter.com/amit_k_goyal" target="_blank" rel="noopener">X / Twitter</a></li>
      <li><a href="https://econschool.in" target="_blank" rel="noopener">Econschool</a></li>
    </ul>
  </section>

</Base>

<style>
  .cv-header {
    padding: 2rem 0 2.5rem;
    max-width: 44rem;
  }
  .cv-header h1 {
    margin: 0.25rem 0 0.75rem;
  }
  .cv-tagline {
    font-size: 1.2rem;
    color: var(--ink);
    margin: 0 0 0.75rem;
  }
  .cv-meta {
    color: var(--ink-faint);
    font-style: italic;
    font-size: 0.95rem;
    margin: 0;
  }
  .cv-download {
    margin-top: 1.75rem;
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .cv-download a {
    font-family: var(--display);
    font-size: 1.15rem;
    border-bottom: 1px solid var(--terracotta-soft);
  }
  .cv-updated {
    font-style: italic;
    color: var(--ink-faint);
    font-size: 0.9rem;
  }

  .cv-section {
    padding: 1.5rem 0;
  }
  .cv-section h2 {
    margin-bottom: 1.5rem;
  }
  .cv-prose {
    max-width: 60ch;
    color: var(--ink);
    font-size: 1.05rem;
  }

  .cv-subhead {
    font-family: var(--serif);
    font-variant: small-caps;
    letter-spacing: 0.08em;
    color: var(--terracotta);
    font-size: 0.95rem;
    font-weight: 600;
    margin: 1.75rem 0 0.6rem;
  }
  .cv-subhead:first-of-type { margin-top: 0; }

  /* Entry blocks with date column */
  .cv-entries {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .cv-entry {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 2rem;
    align-items: baseline;
  }
  .cv-date {
    font-family: var(--display);
    font-style: italic;
    color: var(--ink-faint);
    font-size: 1rem;
    padding-top: 0.15rem;
  }
  .cv-body { max-width: 50rem; }
  .cv-entry-title {
    font-family: var(--display);
    font-variant: normal;
    letter-spacing: 0;
    color: var(--violet);
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 0.25rem;
  }
  .cv-org {
    margin: 0 0 0.5rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  .cv-detail {
    margin: 0;
    color: var(--ink);
    font-size: 0.98rem;
    max-width: 58ch;
  }

  /* Generic list (used for research, teaching, presentations, fellowships) */
  .cv-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cv-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--rule);
    font-size: 0.98rem;
  }
  .cv-list li:last-child { border-bottom: 0; }
  .cv-list--tight li { padding: 0.4rem 0; font-size: 0.95rem; }

  .cv-course { color: var(--ink); }
  .cv-when {
    font-family: var(--display);
    font-style: italic;
    color: var(--ink-faint);
    font-size: 0.92rem;
    white-space: nowrap;
  }

  /* Research papers — title + meta + links, multi-line per item */
  .cv-list li:has(.cv-paper-title) {
    grid-template-columns: 1fr;
    gap: 0.2rem;
    padding: 0.85rem 0;
  }
  .cv-paper-title {
    font-family: var(--display);
    color: var(--violet);
    font-size: 1.15rem;
    font-weight: 500;
  }
  .cv-paper-meta {
    color: var(--ink-soft);
    font-style: italic;
    font-size: 0.95rem;
  }
  .cv-paper-links {
    color: var(--ink-faint);
    font-size: 0.95rem;
    margin-top: 0.15rem;
  }
  .cv-paper-links a { border-bottom: 1px solid var(--terracotta-soft); }

  /* Elsewhere links */
  .cv-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--ink-soft);
    font-size: 1rem;
  }
  .cv-links li { line-height: 1.6; border: 0; padding: 0; display: block; }

  @media (max-width: 700px) {
    .cv-entry {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .cv-list li {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
    .cv-when {
      font-size: 0.88rem;
    }
  }
</style>