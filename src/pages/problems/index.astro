---
import Base from '../../layouts/Base.astro';

const problems = [
  {
    topic: 'Consumer theory',
    title: 'Perfect substitutes',
    blurb: 'Optimal choice when indifference curves are straight lines — a corner solution — with a companion bus-versus-metro exercise.',
    pdf: '/problems/perfect-substitutes.pdf',
    video: 'https://youtu.be/qKRKmEKNqFQ',
  },

  {
    topic: 'Consumer theory',
    title: 'Perfect complements',
    blurb: 'Goods used in fixed proportion, so the optimum sits at the kink — with a dal-and-rice exercise.',
    pdf: '/problems/perfect-complements.pdf',
    video: 'https://youtu.be/S4v03C39jAI',
  },  
];
---

<Base
  title="Problems — Amit Goyal"
  description="Worked problems with video walkthroughs, each paired with an exercise, to accompany the Econschool YouTube lectures."
  current="problems"
>
  <section style="padding: 2rem 0 3rem;">
    <p class="eyebrow">To go with the lectures</p>
    <h1 style="font-size: clamp(2rem, 4vw, 3.25rem); margin-bottom: 1rem;">
      Problems
    </h1>
    <p style="max-width: 60ch; font-size: 1.1rem; color: var(--ink); line-height: 1.6;">
      Problems to accompany the YouTube lectures. Each PDF has one solved problem with
      a video walkthrough and one exercise without a solution.
    </p>
  </section>

  <hr class="rule-sage" />

  <section class="problem-list">
    {problems.map((p) => (
      <article class="problem-row">
        <p class="problem-topic">{p.topic}</p>
        <h2 class="problem-title">{p.title}</h2>
        <p class="problem-blurb">{p.blurb}</p>
        <p class="problem-links">
          <a href={p.pdf} target="_blank" rel="noopener noreferrer">Download PDF</a>
          <span class="sep"> · </span>
          <a href={p.video} target="_blank" rel="noopener noreferrer">Watch on YouTube</a>
        </p>
      </article>
    ))}
  </section>
</Base>

<style>
  .problem-list { padding: 1rem 0 2rem; }
  .problem-row {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .problem-row:first-child { border-top: 1px solid var(--rule); }
  .problem-topic {
    font-variant: small-caps;
    letter-spacing: 0.12em;
    color: var(--terracotta);
    font-size: 0.85rem;
    margin: 0 0 0.35rem;
  }
  .problem-title {
    font-family: var(--display);
    color: var(--violet);
    font-weight: 500;
    font-size: 1.75rem;
    margin: 0 0 0.5rem;
  }
  .problem-blurb {
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 0.75rem;
  }
  .problem-links { margin: 0; }
  .problem-links .sep { color: var(--ink-faint); }
</style>